
# Copy this to .env and fill in your values

DATABASE_URL="sqlserver://localhost;database=ArtiGate;trustServerCertificate=true;integratedSecurity=true"
JWT_SECRET="<your-secure-secret-here-min-32-chars>"
JWT_EXPIRES_IN="1d"
CORS_ORIGIN="http://localhost:3001"
PORT=3000
BCRYPT_SALT_ROUNDS=10
BRASIL_API_BASE_URL="https://brasilapi.com.br"
UPLOAD_DIR="uploads/articles"
MAX_PDF_BYTES=10485760
PAYMENT_DEFAULT_CURRENCY="BRL"
MERCADO_PAGO_ACCESS_TOKEN="<your-mercado-pago-access-token>"
MERCADO_PAGO_PUBLIC_KEY="<your-mercado-pago-public-key>"
MERCADO_PAGO_WEBHOOK_SECRET="<your-webhook-secret>"
MERCADO_PAGO_NOTIFICATION_URL="https://your-domain.example/payment/webhook"

# Set to "true" to bypass the gateway and persist a successful Payment row locally (for tests/dev).
ENABLE_PAYMENT_MOCK=true
