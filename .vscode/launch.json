{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "Nx Serve Backend API",
            "command": "npx nx serve",
            "cwd": "${workspaceFolder}/backend-api",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "Nx Serve Frontend",
            "command": "npx nx serve",
            "cwd": "${workspaceFolder}/frontend",
            "env": {
                "NODE_ENV": "development"
            }
        }
    ],
    "compounds": [
        {
            "name": "Launch Full Stack",
            "configurations": [
                "Nx Serve Backend API",
                "Nx Serve Frontend"
            ],
            "stopAll": true
        }
    ]
}