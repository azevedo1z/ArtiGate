generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Role {
  id String @id @default(uuid())
  name String @unique
  createdOn DateTime @default(now())
  deletedOn DateTime?

  userRoles UserRole[]
}

model UserRole {
  id String @id @default(uuid())
  userId String
  roleId String
  createdOn DateTime @default(now())
  deletedOn DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model User {
  id String @id @default(uuid())
  name String
  homeAddressId String
  jobAddressId String
  phone String
  email String @unique
  badgeUrl String
  passwordHash String
  createdOn DateTime @default(now())
  updatedOn DateTime @updatedAt
  deletedOn DateTime?

  articles ArticleAuthor[]
  reviews Review[]
  payments Payment[]
  userRoles UserRole[]
  uploadedAttachments ArticleAttachment[]

  homeAddress Address @relation("Home", fields: [homeAddressId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  jobAddress Address @relation("Job", fields: [jobAddressId], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model Address {
  id String @id @default(uuid())
  zipCode String
  street String
  complement String?
  neighborhood String
  city String
  state String
  country String @default("Brazil")
  createdOn DateTime @default(now())
  updatedOn DateTime @updatedAt
  deletedOn DateTime?

  homeUsers User[] @relation("Home")
  jobUsers User[] @relation("Job")
}

model Article {
  id String @id @default(uuid())
  summary String
  scoreAvg Float @default(0)
  createdOn DateTime @default(now())
  updatedOn DateTime @updatedAt
  deletedOn DateTime?

  authors ArticleAuthor[]
  reviews Review[]
  attachments ArticleAttachment[]
}

model ArticleAttachment {
  id String @id @default(uuid())
  articleId String
  storedName String @unique
  originalName String
  mimeType String
  size Int
  checksum String
  uploaderId String
  createdOn DateTime @default(now())
  deletedOn DateTime?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([articleId])
  @@index([uploaderId])
}

model ArticleAuthor {
  id String @id @default(uuid())
  articleId String
  userId String
  createdOn DateTime @default(now())
  deletedOn DateTime?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@index([articleId])
  @@index([userId])
}

model Review {
  id String @id @default(uuid())
  articleId String
  reviewerId String
  score Float @default(0)
  commentary String
  createdOn DateTime @default(now())
  updatedOn DateTime @updatedAt
  deletedOn DateTime?

  reviewer User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, reviewerId])
  @@index([articleId])
  @@index([reviewerId])
}

model Payment {
  id String @id @default(uuid())
  userId String
  amount Decimal @db.Decimal(12, 2)
  currency String @default("BRL")
  status String @default("pending")
  description String?
  paymentMethodId String?
  payerEmail String
  gatewayPaymentId String? @unique
  idempotencyKey String @unique
  failureReason String?
  rawGatewayResponse String? @db.NVarChar(Max)
  createdOn DateTime @default(now())
  updatedOn DateTime @updatedAt
  deletedOn DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gatewayPaymentId])
  @@index([status])
}